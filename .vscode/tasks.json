{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dotnet: clean",
      "command": "dotnet",
      "type": "process",
      "args": [
        "clean",
        "${workspaceFolder}/src/MX.CraftPledge.sln"
      ]
    },
    {
      "label": "dotnet: build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/MX.CraftPledge.sln",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "dotnet: test",
      "command": "dotnet",
      "type": "process",
      "args": [
        "test",
        "${workspaceFolder}/src/MX.CraftPledge.sln",
        "--filter",
        "FullyQualifiedName!~IntegrationTests"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "dotnet: format",
      "command": "dotnet",
      "type": "process",
      "args": [
        "format",
        "${workspaceFolder}/src/MX.CraftPledge.sln",
        "--verify-no-changes"
      ]
    },
    {
      "label": "dotnet: publish",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/src/MX.CraftPledge.Web/MX.CraftPledge.Web.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: run-apphost",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/MX.CraftPledge.AppHost/MX.CraftPledge.AppHost.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true,
      "dependsOn": "dotnet: build"
    },
    {
      "label": "dotnet: run-web",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/MX.CraftPledge.Web/MX.CraftPledge.Web.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true,
      "dependsOn": "dotnet: build"
    },
    {
      "label": "dotnet: watch-web",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/src/MX.CraftPledge.Web/MX.CraftPledge.Web.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true
    }
  ]
}