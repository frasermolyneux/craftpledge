@{
    ViewData["Title"] = "For Consumers";
}

<section class="page-header">
    <div class="container">
        <h1>For Consumers</h1>
        <p class="lead">Know what you&rsquo;re buying. Know who made it. Know it&rsquo;s real.</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h2>What the CraftPledge mark means for you</h2>
                <hr class="section-divider" style="margin-left:0;" />
                <p class="text-warm-gray">
                    When you see the CraftPledge mark on a product or service, it means a real human made it &mdash;
                    and they&rsquo;ve been verified. It&rsquo;s not a marketing claim or a vague promise. It&rsquo;s a
                    certified, accountable pledge backed by a transparent verification process.
                </p>
                <p class="text-warm-gray">
                    In an age where AI can generate almost anything, the CraftPledge mark helps you make informed
                    choices about the products, content, and services you support.
                </p>
            </div>
            <div class="col-lg-5 offset-lg-1">
                <div class="card card-cp">
                    <div class="card-body text-center">
                        <div style="font-size:4rem;">👁️</div>
                        <h4 class="text-terracotta mt-3">Look for the Mark</h4>
                        <p class="text-warm-gray">The CraftPledge certification mark appears on products, websites, and packaging of verified creators and businesses.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <div class="text-center mb-5">
            <h2>Understanding the tiers</h2>
            <hr class="section-divider" />
            <p class="text-warm-gray" style="max-width:650px;margin:0 auto;">
                Not all human-made work is the same. Our three-tier system makes it easy to understand exactly
                how a product or service was created.
            </p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card card-cp tier-card tier-assisted">
                    <div class="card-body">
                        <div class="tier-icon">🥉</div>
                        <h4 class="card-title">Craft Assisted</h4>
                        <p class="text-warm-gray">A human led the work. AI may have been used as a supporting tool, but a person was in charge and takes responsibility.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-cp tier-card tier-verified">
                    <div class="card-body">
                        <div class="tier-icon">🥈</div>
                        <h4 class="card-title">Craft Verified</h4>
                        <p class="text-warm-gray">No AI was used to create this product or service. It was made entirely by human hands and minds.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-cp tier-card tier-pure">
                    <div class="card-body">
                        <div class="tier-icon">🥇</div>
                        <h4 class="card-title">Craft Pure</h4>
                        <p class="text-warm-gray">No AI anywhere &mdash; from raw materials to final delivery. The highest possible standard of human craft.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="text-center mb-5">
            <h2>Why it matters</h2>
            <hr class="section-divider" />
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card card-cp text-center">
                    <div class="card-body">
                        <div class="value-icon">💡</div>
                        <h4 class="card-title">Informed Choices</h4>
                        <p class="text-warm-gray">You deserve to know whether the work you&rsquo;re paying for was made by a person or generated by a machine.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-cp text-center">
                    <div class="card-body">
                        <div class="value-icon">🧑‍🎨</div>
                        <h4 class="card-title">Support Livelihoods</h4>
                        <p class="text-warm-gray">When you choose CraftPledge-certified products, you&rsquo;re supporting real people and their craft.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-cp text-center">
                    <div class="card-body">
                        <div class="value-icon">🔒</div>
                        <h4 class="card-title">Trust &amp; Accountability</h4>
                        <p class="text-warm-gray">CraftPledge certification is verified and accountable. Creators stand behind their claims.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="container">
        <h2>Look for the Mark</h2>
        <p>Next time you&rsquo;re choosing a product, service, or piece of content &mdash; look for the CraftPledge mark and know it&rsquo;s real.</p>
        <a asp-controller="Home" asp-action="Tiers" class="btn btn-primary btn-lg me-2">Explore the Tiers</a>
        <a asp-controller="Home" asp-action="Faq" class="btn btn-outline-light btn-lg">Read the FAQ</a>
    </div>
</section>
