@{
    ViewData["Title"] = "For Creators";
}

<section class="page-header">
    <div class="container">
        <h1>For Creators &amp; Businesses</h1>
        <p class="lead">Stand out. Stand behind your work. Stand with the craft.</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h2>Why take the pledge?</h2>
                <hr class="section-divider" style="margin-left:0;" />
                <p class="text-warm-gray">
                    In a world flooded with AI-generated content, your human-made work is more valuable than ever.
                    But only if people know it&rsquo;s real. CraftPledge gives you a trusted, verifiable way to
                    prove that a human made your work &mdash; and to stand behind that claim.
                </p>
            </div>
            <div class="col-lg-5 offset-lg-1">
                <div class="card card-cp">
                    <div class="card-body text-center">
                        <div style="font-size:4rem;">🛡️</div>
                        <h4 class="text-terracotta mt-3">The CraftPledge Mark</h4>
                        <p class="text-warm-gray">A certification your customers can trust, backed by verification and accountability.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <div class="text-center mb-5">
            <h2>What you gain</h2>
            <hr class="section-divider" />
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card card-cp text-center">
                    <div class="card-body">
                        <div class="value-icon">✨</div>
                        <h4 class="card-title">Stand Out</h4>
                        <p class="text-warm-gray">Differentiate your work in a sea of AI-generated content. The CraftPledge mark signals quality and authenticity.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card card-cp text-center">
                    <div class="card-body">
                        <div class="value-icon">🤝</div>
                        <h4 class="card-title">Build Trust</h4>
                        <p class="text-warm-gray">Give your customers and clients confidence that real humans created the work they&rsquo;re paying for.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card card-cp text-center">
                    <div class="card-body">
                        <div class="value-icon">🌍</div>
                        <h4 class="card-title">Join a Community</h4>
                        <p class="text-warm-gray">Become part of a growing movement of creators and businesses who value human craft and transparency.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card card-cp text-center">
                    <div class="card-body">
                        <div class="value-icon">📈</div>
                        <h4 class="card-title">Add Value</h4>
                        <p class="text-warm-gray">Research shows consumers increasingly prefer human-made products. Certification makes that preference actionable.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="text-center mb-5">
            <h2>How it works</h2>
            <hr class="section-divider" />
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="text-center mb-3">
                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-cream border" style="width:60px;height:60px;font-size:1.5rem;font-weight:700;color:var(--cp-terracotta);border-color:var(--cp-terracotta)!important;">1</span>
                </div>
                <h4 class="text-center">Choose Your Tier</h4>
                <p class="text-warm-gray text-center">Select the certification level that honestly reflects how your work is made &mdash; Craft Assisted, Craft Verified, or Craft Pure.</p>
            </div>
            <div class="col-md-4">
                <div class="text-center mb-3">
                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-cream border" style="width:60px;height:60px;font-size:1.5rem;font-weight:700;color:var(--cp-terracotta);border-color:var(--cp-terracotta)!important;">2</span>
                </div>
                <h4 class="text-center">Get Verified</h4>
                <p class="text-warm-gray text-center">Submit your work and process for review. Our verification system confirms your claims are accurate and honest.</p>
            </div>
            <div class="col-md-4">
                <div class="text-center mb-3">
                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-cream border" style="width:60px;height:60px;font-size:1.5rem;font-weight:700;color:var(--cp-terracotta);border-color:var(--cp-terracotta)!important;">3</span>
                </div>
                <h4 class="text-center">Display Your Mark</h4>
                <p class="text-warm-gray text-center">Use the CraftPledge certification mark on your products, website, and marketing to show the world your work is human-made.</p>
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="container">
        <h2>Take the Pledge</h2>
        <p>Ready to certify your work as human-made? Join the growing community of creators who stand behind their craft.</p>
        <p style="font-size:0.9rem;opacity:0.8;">We&rsquo;d certify ourselves, but we have some <a asp-controller="Home" asp-action="OurStory" style="color:#FFF8F0;text-decoration:underline;">explaining to do first</a>.</p>
        <a asp-controller="Home" asp-action="Faq" class="btn btn-primary btn-lg me-2">Learn More in FAQ</a>
        <a asp-controller="Home" asp-action="Tiers" class="btn btn-outline-light btn-lg">View the Tiers</a>
    </div>
</section>
