@using MX.CraftPledge.Web.Models
@{
    ViewData["Title"] = "Home";
    var latestPost = BlogPost.All.FirstOrDefault();
    var showBanner = latestPost is not null
        && latestPost.Published.ToDateTime(TimeOnly.MinValue, DateTimeKind.Utc).AddDays(7) >= DateTime.UtcNow;
}

@if (showBanner && latestPost is not null)
{
    <div class="new-post-banner">
        📢 New post: <a asp-controller="Blog" asp-action="Post" asp-route-slug="@latestPost.Slug">@latestPost.Title</a>
    </div>
}

<!-- Hero -->
<section class="hero-section">
    <div class="container">
        <h1>Made by humans. Verified.</h1>
        <p class="lead">
            CraftPledge is a trusted certification mark for human-made work in the age of AI.
            We make the human behind the work visible again.
        </p>
        <p class="mb-4" style="font-size:0.9rem;opacity:0.8;">
            (Yes, we see the irony. <a asp-controller="Home" asp-action="OurStory" style="color:#FFF8F0;text-decoration:underline;">We address it head-on.</a>)
        </p>
        <a asp-controller="Home" asp-action="Tiers" class="btn btn-primary btn-lg me-2">Take the Pledge</a>
        <a asp-controller="Home" asp-action="Manifesto" class="btn btn-outline-light btn-lg">Read the Manifesto</a>
    </div>
</section>

<!-- Values -->
<section class="section">
    <div class="container">
        <div class="text-center mb-5">
            <h2>Because craft still matters</h2>
            <hr class="section-divider" />
            <p class="text-warm-gray" style="max-width:650px;margin:0 auto;">
                In a world where anyone can generate anything, the people who truly make things deserve to be seen.
            </p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card card-cp text-center">
                    <div class="card-body">
                        <div class="value-icon">🔍</div>
                        <h3 class="card-title">Transparency</h3>
                        <p class="text-warm-gray">Know whether the work you&rsquo;re buying, reading, or using was made by a human or generated by a machine.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-cp text-center">
                    <div class="card-body">
                        <div class="value-icon">✋</div>
                        <h3 class="card-title">Craft</h3>
                        <p class="text-warm-gray">Celebrate the skill, experience, and dedication that goes into genuinely human-made products and services.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-cp text-center">
                    <div class="card-body">
                        <div class="value-icon">✅</div>
                        <h3 class="card-title">Accountability</h3>
                        <p class="text-warm-gray">A verifiable pledge backed by real people who stand behind their claims. Not a label &mdash; a commitment.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Tiers Overview -->
<section class="section section-alt">
    <div class="container">
        <div class="text-center mb-5">
            <h2>Three levels of commitment</h2>
            <hr class="section-divider" />
            <p class="text-warm-gray" style="max-width:650px;margin:0 auto;">
                We believe honesty requires nuance. Our tiered certification reflects the real spectrum of human and AI involvement.
            </p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card card-cp tier-card tier-assisted">
                    <div class="card-body">
                        <div class="tier-icon">🥉</div>
                        <h3 class="card-title">Craft Assisted</h3>
                        <p class="text-warm-gray">AI may have been used as a supporting tool, but a human led, shaped, and took responsibility for the final output.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-cp tier-card tier-verified">
                    <div class="card-body">
                        <div class="tier-icon">🥈</div>
                        <h3 class="card-title">Craft Verified</h3>
                        <p class="text-warm-gray">No AI was used in creating the final product or service. Conceived, created, and delivered by human hands and minds.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-cp tier-card tier-pure">
                    <div class="card-body">
                        <div class="tier-icon">🥇</div>
                        <h3 class="card-title">Craft Pure</h3>
                        <p class="text-warm-gray">No AI was used anywhere in the supply chain &mdash; from origin to delivery. The highest standard of human craft.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <a asp-controller="Home" asp-action="Tiers" class="btn btn-outline-primary btn-lg">Learn About the Tiers</a>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta-section">
    <div class="container">
        <h2>Ready to stand behind your craft?</h2>
        <p>Whether you&rsquo;re a creator, a business, or a consumer &mdash; CraftPledge gives you a way to champion human-made work.</p>
        <a asp-controller="Home" asp-action="ForCreators" class="btn btn-primary btn-lg me-2">Take the Pledge</a>
        <a asp-controller="Home" asp-action="ForConsumers" class="btn btn-outline-light btn-lg">Learn More</a>
    </div>
</section>
